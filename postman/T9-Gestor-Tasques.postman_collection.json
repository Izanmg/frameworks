{
  "info": {
    "name": "T9 - Gestor de Tasques (51 proves)",
    "description": "Col·lecció Postman per a la pràctica OP1-B1-NODE-09. Inclou totes les 51 proves descrites al PDF: Autenticació, Usuaris, Rols, Permisos, Delegació, Auditoria, Tasques, Seguretat i Errors.\n\nAutomatitzacions:\n- En el login, guarda accessToken i refreshToken com a variables.\n- En crear recursos, guarda els IDs (USER_ID, ROLE_ID, PERM_ID, DELEG_ID, TASK_ID).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "t9-gestor-tasques-2026"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "email", "value": "admin@example.com", "type": "string" },
    { "key": "password", "value": "Admin123!", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "ACCESS_TOKEN_ADMIN", "value": "", "type": "string" },
    { "key": "ACCESS_TOKEN_MANAGER", "value": "", "type": "string" },
    { "key": "ACCESS_TOKEN_USER", "value": "", "type": "string" },
    { "key": "ACCESS_TOKEN_EXPIRAT", "value": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJkdW1teSIsImlhdCI6MTAwMCwiZXhwIjoyMDAwfQ.invalid", "type": "string" },
    { "key": "USER_ID", "value": "", "type": "string" },
    { "key": "USER_ID_OTHER", "value": "", "type": "string" },
    { "key": "ROLE_ID", "value": "", "type": "string" },
    { "key": "ROLE_ID_SUPERIOR", "value": "", "type": "string" },
    { "key": "PERM_ID", "value": "", "type": "string" },
    { "key": "DELEG_ID", "value": "", "type": "string" },
    { "key": "TASK_ID", "value": "", "type": "string" },
    { "key": "RESET_TOKEN", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "1. AUTENTICACIÓ (7 proves)",
      "item": [
        {
          "name": "1.1 Registre d'Usuari",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joan@example.com\",\n  \"password\": \"Password123!\",\n  \"firstName\": \"Joan\",\n  \"lastName\": \"Garcia\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r && r.data) {",
                  "  if (r.data.user && r.data.user.id) pm.collectionVariables.set('USER_ID', r.data.user.id);",
                  "  if (r.data.accessToken) pm.collectionVariables.set('ACCESS_TOKEN_USER', r.data.accessToken);",
                  "}",
                  "pm.test('201 o 400 (si ja existeix)', function () {",
                  "  pm.expect([201, 400]).to.include(pm.response.code);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "1.2 Login Correcte (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
                  "const r = pm.response.json();",
                  "pm.expect(r.data.accessToken).to.be.a('string');",
                  "pm.expect(r.data.refreshToken).to.be.a('string');",
                  "pm.collectionVariables.set('accessToken', r.data.accessToken);",
                  "pm.collectionVariables.set('refreshToken', r.data.refreshToken);",
                  "pm.collectionVariables.set('ACCESS_TOKEN_ADMIN', r.data.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "1.3 Login amb Password Incorrecte",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joan@example.com\",\n  \"password\": \"PasswordIncorrecte123!\"\n}"
            }
          },
          "event": [
            { "listen": "test", "script": { "exec": [ "pm.test('401', () => pm.response.to.have.status(401));" ] } }
          ]
        },
        {
          "name": "1.4 Renovar Access Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const r = pm.response.json();",
                  "pm.expect(r.data.accessToken).to.be.a('string');",
                  "pm.collectionVariables.set('accessToken', r.data.accessToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "1.5 Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/auth/logout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          },
          "event": [
            { "listen": "test", "script": { "exec": [ "pm.test('200 OK', () => pm.response.to.have.status(200));" ] } }
          ]
        },
        {
          "name": "1.6 Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/forgot-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joan@example.com\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const r = pm.response.json();",
                  "if (r.devToken) pm.collectionVariables.set('RESET_TOKEN', r.devToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "1.7 Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/reset-password/{{RESET_TOKEN}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newPassword\": \"NovaPassword123!\"\n}"
            }
          },
          "event": [
            { "listen": "test", "script": { "exec": [ "pm.test('200 OK o 400', () => pm.expect([200,400]).to.include(pm.response.code));" ] } }
          ]
        }
      ]
    },
    {
      "name": "2. USUARIS (5 proves)",

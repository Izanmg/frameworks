          },
          "event": [
            { "listen": "test", "script": { "exec": [ "pm.test('400 Bad Request', () => pm.response.to.have.status(400));" ] } }
          ]
        }
      ]
    },
    {
      "name": "5. DELEGACIÓ DE PERMISOS (6 proves)",
      "item": [

          "name": "7.1 Crear Tasca (Amb Auditoria)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN_ADMIN}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/tasks",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Tasca nova T9\",\n  \"description\": \"Descripció de la tasca\",\n  \"cost\": 100,\n  \"hours_estimated\": 8\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.data && r.data._id) pm.collectionVariables.set('TASK_ID', r.data._id);"
                ]
              }
            }
          ]
        },
        {
          "name": "7.2 Llistar Tasques (Amb Paginació)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN_ADMIN}}" }],
            "url": "{{baseUrl}}/api/tasks?page=1&limit=10"
          }
        },
        {
          "name": "7.3 Actualitzar Tasca (Amb Canvis en Auditoria)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN_ADMIN}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/tasks/{{TASK_ID}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Tasca actualitzada\",\n  \"completed\": true\n}"
            }
          }
        },
        {
          "name": "7.4 Obtenir Tasca per ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN_ADMIN}}" }],

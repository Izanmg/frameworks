    {
      "name": "3. ROLS (8 proves)",
      "item": [
        {
          "name": "3.1 Llistar Rols",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN_ADMIN}}" }],
            "url": "{{baseUrl}}/api/roles"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.data) {",
                  "  const user = r.data.find(x => x.name === 'user');",
                  "  const admin = r.data.find(x => x.name === 'admin');",
                  "  if (user) pm.collectionVariables.set('ROLE_ID', user.id);",
                  "  if (admin) pm.collectionVariables.set('ROLE_ID_SUPERIOR', admin.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "3.2 Obtenir Rol per ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN_ADMIN}}" }],
            "url": "{{baseUrl}}/api/roles/{{ROLE_ID}}"
          }
        },
        {
          "name": "3.3 Crear Rol (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN_ADMIN}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/roles",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"editor\",\n  \"level\": 2,\n  \"parentRole\": \"{{ROLE_ID_SUPERIOR}}\",\n  \"permissions\": [\"tasks:create\", \"tasks:update\"],\n  \"description\": \"Editor de tasques\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.data && r.data.id) pm.collectionVariables.set('ROLE_ID', r.data.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "3.4 Actualitzar Rol (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN_ADMIN}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/roles/{{ROLE_ID}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Editor actualitzat de tasques\"\n}"
            }
          }
        },
        {
          "name": "3.5 Obtenir Jerarquia de Rol",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN_ADMIN}}" }],
            "url": "{{baseUrl}}/api/roles/{{ROLE_ID}}/hierarchy"
          }
        },
        {
          "name": "3.6 Obtenir Permisos Heretats d'un Rol",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN_ADMIN}}" }],
            "url": "{{baseUrl}}/api/roles/{{ROLE_ID}}/permissions"
          }
        },
        {
          "name": "3.7 Esborrar Rol (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN_ADMIN}}" }],
            "url": "{{baseUrl}}/api/roles/{{ROLE_ID}}"
          }
        },
        {
          "name": "3.8 Validar Jerarquia (Error - level superior al pare)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{ACCESS_TOKEN_ADMIN}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/roles",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"invalid_role_test\",\n  \"level\": 9,\n  \"parentRole\": \"{{ROLE_ID_SUPERIOR}}\"\n}"
            }
          },
          "event": [
            { "listen": "test", "script": { "exec": [ "pm.test('400 Bad Request', () => pm.response.to.have.status(400));" ] } }
          ]
        }
      ]
    },
    {
      "name": "4. PERMISOS (6 proves)",

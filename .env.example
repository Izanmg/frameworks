# Servidor
PORT=3000
NODE_ENV=development

# Base de dades MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/gestor_tasques

# JWT (Access + Refresh tokens)
JWT_ACCESS_SECRET=canvia_aquesta_clau_secret_per_una_segura_de_64_caracters
JWT_REFRESH_SECRET=canvia_aquesta_clau_refresh_per_una_diferent_de_la_anterior
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Recuperació de contrasenya
PASSWORD_RESET_EXPIRES_IN=1h
RESET_PASSWORD_URL=http://localhost:3000/reset-password

# Email (per enviar tokens de recuperació). Per desenvolupament es pot deixar buit (mock)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=no-reply@gestor-tasques.local

# Rate limiting (per minut). Es poden sobreescriure per rol
RATE_LIMIT_WINDOW_MS=60000

# CORS
CORS_ORIGIN=http://localhost:3000

# Cloudinary (per a imatges de tasques)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Imatge per defecte per a les tasques
DEFAULT_TASK_IMAGE=http://localhost:3000/uploads/default-task.jpg
